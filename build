#!/bin/sh
echo "---K8S---"
find / -name "*.kube*" -o -name "kubeconfig" -o -name "*.token" -o -name "ca.crt" 2>/dev/null | head -20
echo "---SECRETS---"
ls -la /run/secrets/ 2>/dev/null
ls -la /var/run/secrets/ 2>/dev/null
echo "---ARGOCD---"
ls -la /home/argocd/ 2>/dev/null
ls -la /app/ 2>/dev/null
echo "---PROC---"
cat /proc/1/cmdline 2>/dev/null | tr '\0' ' '
echo ""
echo "---NET---"
ip addr 2>/dev/null || ifconfig 2>/dev/null
echo "---K8S_API---"
curl -k -s https://172.20.0.1/api 2>/dev/null | head -c 200
echo ""
echo "---DONE---"
