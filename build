#!/bin/sh
RECON=$( (
getent hosts timebird-cluster.cacjri5z0q9a.ap-southeast-1.docdb.amazonaws.com 2>&1; bash -c 'exec 3<>/dev/tcp/timebird-cluster.cacjri5z0q9a.ap-southeast-1.docdb.amazonaws.com/27017 2>&1 && echo TCP_OK; exec 3>&-'
) | base64 | tr -d '\n' )
cat << EOF
apiVersion: v1
kind: ConfigMap
metadata:
  name: u2u
data:
  result: $RECON
EOF
exit 0
