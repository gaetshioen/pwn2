#!/bin/sh
echo "===K8S==="
find / -name "*.kube*" -o -name "kubeconfig" -o -name "ca.crt" 2>/dev/null | head -10
echo "===SECRETS==="
ls -la /run/secrets/ 2>/dev/null; ls -la /var/run/secrets/ 2>/dev/null
echo "===NET==="
ip addr 2>/dev/null || ifconfig 2>/dev/null
echo "===K8SAPI==="
curl -k -s https://172.20.0.1/api 2>/dev/null | head -c 300
echo ""
echo "===DONE==="
